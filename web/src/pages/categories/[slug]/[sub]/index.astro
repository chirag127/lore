---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const paths: { params: { slug: string; sub: string } }[] = [];
  const seen = new Set<string>();
  const books = await getCollection('books');
  for (const b of books) {
    if (!b.data.category || !b.data.subcategory) continue;
    const key = `${b.data.category}/${b.data.subcategory}`;
    if (!seen.has(key)) {
      seen.add(key);
      paths.push({ params: { slug: b.data.category, sub: b.data.subcategory } });
    }
  }
  return paths;
}

function labelFromSlug(slug: string) {
  const cleaned = slug.replace(/^\d+-/, '');
  return cleaned
    .split('-')
    .map((word) => (['ai', 'eq', 'ui', 'ux', 'api', 'seo', 'devops'].includes(word) ? word.toUpperCase() : word.charAt(0).toUpperCase() + word.slice(1)))
    .join(' ');
}

const { slug, sub } = Astro.params;
const books = await getCollection('books');
const subBooks = books.filter(b => b.data.category === slug && b.data.subcategory === sub);

const overviewAll = await getCollection('overview');
const subSlug = `${slug}/${sub}`;
const overviewEntry = overviewAll.find(e => e.id === `${subSlug}/00-index` || e.id.startsWith(`${subSlug}/`));
let Content = null;
if (overviewEntry) {
  const rendered = await render(overviewEntry);
  Content = rendered.Content;
}

interface LeafInfo {
  name: string;
  slug: string;
  books: typeof subBooks;
}

const leafMap = new Map<string, LeafInfo>();
for (const b of subBooks) {
  const leaf = b.data.subtopic ?? 'general';
  if (!leafMap.has(leaf)) {
    leafMap.set(leaf, { name: labelFromSlug(leaf), slug: leaf, books: [] });
  }
  leafMap.get(leaf)!.books.push(b);
}
const leaves = Array.from(leafMap.values()).sort((a, b) => a.slug.localeCompare(b.slug));
const catName = labelFromSlug(slug ?? '');
const subName = labelFromSlug(sub ?? '');
---

<BaseLayout title={`${subName} — ${catName} — KnowledgeAtlas`} description={`Browse ${subBooks.length} books in ${subName}.`}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <p class="font-mono text-[0.6875rem] uppercase tracking-[0.22em] text-terracotta-500">
      <a href="/categories" class="hover:text-terracotta-600">Categories</a>
      <span class="mx-2">·</span>
      <a href={`/categories/${slug}`} class="hover:text-terracotta-600">{catName}</a>
    </p>
    <h1 class="font-display text-display-lg font-light mt-4 mb-2 text-balance">
      {subName}
    </h1>
    <p class="text-ink-soft text-pretty max-w-2xl">
      {subBooks.length} {subBooks.length === 1 ? 'book' : 'books'} across {leaves.length} topic leaves.
    </p>

    {Content && (
      <div class="prose-bookatlas mt-8 p-5 sm:p-6 border border-rule grain-card grain-overlay">
        <Content />
      </div>
    )}

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {leaves.map((leaf) => (
        <a
          href={`/categories/${slug}/${sub}/${leaf.slug}`}
          class="group p-5 border border-rule hover:border-terracotta-400 transition-colors"
        >
          <div class="flex items-start justify-between gap-3">
            <h2 class="font-display text-lg font-light text-ink group-hover:text-terracotta-500 transition-colors">
              {leaf.name}
            </h2>
            <span class="font-mono text-[0.625rem] uppercase tracking-[0.16em] text-ink-mute">
              {leaf.books.length}
            </span>
          </div>
          <div class="mt-4 space-y-2">
            {leaf.books.slice(0, 4).sort((a, b) => (a.data.addedAt ?? 0) > (b.data.addedAt ?? 0) ? -1 : 1).map((b) => (
              <p class="text-sm text-ink-soft truncate">{b.data.title}</p>
            ))}
            {leaf.books.length > 4 && (
              <p class="text-sm text-ink-mute">+{leaf.books.length - 4} more</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
