---
/*
 * BaseLayout — book·lore chrome. Fully self-contained (no shared @chirag127
 * packages, no auth). Header + Footer + Sidebar + BottomBar are all local.
 */
import '~/styles/global.css'

import Header from '~/components/Header.astro'
import AppSidebarContent from '~/components/AppSidebarContent.astro'
import Footer from '~/components/Footer.astro'
import Sidebar from '~/components/Sidebar.astro'
import BottomBar from '~/components/BottomBar.astro'
import { bottomBarActions } from '~/data/bottombar-actions'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  /** Optional breadcrumb spine for book pages, rendered below the brass rule. */
  breadcrumb?: string
}

const {
  title = `book·lore — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  breadcrumb,
} = Astro.props

const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const ga4Id = import.meta.env.PUBLIC_GA4_ID
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="book·lore" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0F0D13" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Caveat:wght@400;600&family=JetBrains+Mono:wght@400;500&family=Roboto:wght@400;500;700&family=Roboto+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
      />
    )}

    {beaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${beaconToken}"}`}
      />
    )}

    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>{`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga4Id);
        `}</script>
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header breadcrumb={breadcrumb} />
    <div class="layout-body">
      <Sidebar>
        <AppSidebarContent />
      </Sidebar>
      <main id="main" class="layout-main"><slot /></main>
    </div>
    <Footer />
    <BottomBar actions={bottomBarActions} />

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {})
        })
      }
    </script>

    <style>
      .layout-body { display: flex; align-items: flex-start; }
      .layout-main { flex: 1 1 auto; min-width: 0; min-height: 50vh; }
      @media (max-width: 767px) {
        .layout-body { display: block; }
        .layout-main { padding-bottom: 64px; }
      }
    </style>
  </body>
</html>
