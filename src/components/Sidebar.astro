---
/*
 * Sidebar — collapsible aside with pure-CSS mobile toggle. Inlined (was
 * @chirag127/astro-chrome/Sidebar.astro). Fixed left drawer on mobile,
 * sticky rail on desktop. Content comes via the default slot.
 */
---
<input type="checkbox" id="sb-toggle" class="sb-toggle" hidden />
<label for="sb-toggle" class="sb-burger" aria-label="Toggle sidebar"><span></span><span></span><span></span></label>
<aside class="site-sidebar" aria-label="sidebar">
  <nav class="sb-nav"><slot /></nav>
</aside>
<style>
  .sb-toggle { position: absolute; opacity: 0; pointer-events: none; }
  .sb-burger { display: none; position: fixed; top: 12px; left: 12px; z-index: 60; width: 40px; height: 40px; flex-direction: column; justify-content: center; align-items: center; gap: 4px; background: var(--paper); border: 1px solid var(--rule); border-radius: 4px; cursor: pointer; }
  .sb-burger span { display: block; width: 20px; height: 2px; background: var(--ink); }
  .site-sidebar { width: 240px; flex: 0 0 240px; position: sticky; top: 60px; align-self: flex-start; max-height: calc(100vh - 60px); overflow-y: auto; padding: 16px; border-right: 1px solid var(--rule); background: var(--paper-2); }
  .sb-nav { display: flex; flex-direction: column; gap: 4px; }
  @media (max-width: 767px) {
    .sb-burger { display: inline-flex; }
    .site-sidebar { position: fixed; top: 0; left: 0; bottom: 0; z-index: 55; transform: translateX(-100%); transition: transform 0.2s ease; max-height: 100vh; }
    .sb-toggle:checked ~ .site-sidebar { transform: translateX(0); }
  }
</style>
