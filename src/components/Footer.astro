---
/*
 * Footer — book·lore colophon + minimal sitemap. Inlined (was
 * @chirag127/astro-chrome/Footer.astro); trimmed to this app's own links,
 * painted in the book-lore palette. No newsletter/support/family cross-links.
 */
const cols = [
  {
    label: 'Browse',
    items: [
      { name: 'Shelves', url: '/books/' },
      { name: 'Categories', url: '/categories/' },
      { name: 'About', url: '/about/' },
      { name: 'Contact', url: '/contact/' },
    ],
  },
  {
    label: 'Legal',
    items: [
      { name: 'Privacy', url: '/legal/privacy/' },
      { name: 'Terms', url: '/legal/terms/' },
      { name: 'Disclaimer', url: '/legal/disclaimer/' },
      { name: 'Grievance', url: '/legal/grievance/' },
    ],
  },
]
const deployTime = import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString().slice(0, 10)
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev'
---
<footer class="site-footer">
  <hr class="ftr-rule" />
  <div class="ftr-grid">
    {cols.map((col) => (
      <div class="ftr-col">
        <h2 class="ftr-h">{col.label}</h2>
        <ul>
          {col.items.map((l) => (
            <li><a href={l.url}>{l.name}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <hr class="ftr-rule" />
  <div class="ftr-colophon">
    <p class="ftr-line">book·lore — commentary, not catalogue. Built with Astro.</p>
    <p class="ftr-line">Deployed <time datetime={deployTime}>{deployTime}</time> · <code>{gitSha}</code></p>
  </div>
</footer>
<style>
  .site-footer { margin-top: 4rem; background: var(--paper-2); }
  .ftr-rule { border: 0; border-top: 1px solid var(--rule); margin: 0; }
  .ftr-grid { display: grid; grid-template-columns: 1fr; gap: 32px; padding: 32px 16px; max-width: var(--container-spine); margin-inline: auto; }
  .ftr-h { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--ink-mute); font-weight: 500; margin: 0 0 14px; }
  .ftr-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .ftr-col a { color: var(--ink); font-size: 14px; text-decoration: none; }
  .ftr-col a:hover { color: var(--pencil); }
  .ftr-colophon { padding: 16px; max-width: var(--container-spine); margin-inline: auto; }
  .ftr-line { margin: 0; font-family: var(--font-mono); font-size: 11px; color: var(--ink-mute); line-height: 1.7; }
  .ftr-line code { color: var(--ink); }
  @media (min-width: 768px) { .ftr-grid { grid-template-columns: 1fr 1fr; padding: 40px 24px; } }
</style>
