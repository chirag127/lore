---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { ContactForm } from '@chirag127/oriz-ui'
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — Book Lore"
  description="Get in touch about Book Lore — typo, broken link, request a book, or feedback."
>
  <header class="container-prose page-head">
    <p class="eyebrow"><a href="/">Book Lore</a> / Contact</p>
    <h1>Contact</h1>
  </header>

  <section class="container-prose intro">
    <p class="lede">
      Spotted a typo? Want to request a book? Disagree with an analysis?
      Email <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>
      or use the form below — it posts via Web3Forms straight to my inbox.
    </p>
    <p>
      Book Lore summaries are commentary; if you are an author or rights-holder
      and have a concern about a specific entry, please contact the
      <a href="/legal/grievance/">grievance officer</a>.
    </p>
  </section>

  <section class="container-prose form-wrap">
    <ContactForm client:load web3formsKey={web3formsKey} fromName="book-lore.oriz.in contact form" />
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .intro { padding-block: 2rem 1rem; color: var(--color-prose); line-height: 1.7; font-size: 1.0625rem; }
  .intro .lede { font-size: 1.1875rem; color: var(--color-fg); margin: 0 0 1.25rem; }
  .intro a { color: var(--color-accent); }
  .form-wrap { padding-block: 1rem 4rem; }
</style>
