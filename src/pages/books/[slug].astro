---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const books = await getCollection('books')
  return books.map((b) => ({ params: { slug: b.data.slug }, props: { book: b } }))
}

const { book } = Astro.props
const { data } = book

// Try to load the four MDX artifacts associated with this book. They live
// alongside meta.json under mdx/<...>/<slug>/ and ship via separate
// collections; if any are missing we just skip that section.
async function tryLoad(collection: 'overview' | 'content' | 'analysis' | 'narration') {
  try {
    const all = await getCollection(collection as never)
    const match = (all as Array<{ id: string }>).find((entry) =>
      entry.id.replace(/\\/g, '/').toLowerCase().includes(`/${data.slug.toLowerCase()}/`),
    )
    if (!match) return null
    const { Content } = await render(match as never)
    return Content
  } catch {
    return null
  }
}

const Overview = await tryLoad('overview')
const Content = await tryLoad('content')
const Analysis = await tryLoad('analysis')
const Narration = await tryLoad('narration')

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: data.title,
  author: data.authors.map((a) => ({ '@type': 'Person', name: a })),
  datePublished: data.year ? `${data.year}` : undefined,
  isbn: data.isbn13 ?? data.isbn10,
  inLanguage: data.language,
  description: data.excerpt || undefined,
  image: data.cover?.url,
}
---

<BaseLayout
  title={`${data.title} — Book Lore`}
  description={data.excerpt || `Structured summary of ${data.title}${data.authors[0] ? ` by ${data.authors[0]}` : ''}.`}
  jsonLd={jsonLd}
>
  <article class="container-page book">
    <header class="book-head">
      <p class="eyebrow"><a href="/">Book Lore</a> / <a href="/books/">Books</a></p>
      <h1>{data.title}</h1>
      {data.subtitle && <p class="subtitle">{data.subtitle}</p>}
      <p class="byline">
        {data.authors.length > 0 && <span>{data.authors.join(', ')}</span>}
        {data.year && <span> · {data.year}</span>}
        {data.publisher && <span> · {data.publisher}</span>}
      </p>
      {data.tags.length > 0 && (
        <ul class="tag-row">
          {data.tags.slice(0, 8).map((t) => <li class="tag">{t}</li>)}
        </ul>
      )}
    </header>

    {data.excerpt && (
      <section class="container-prose section">
        <p class="lede">{data.excerpt}</p>
      </section>
    )}

    {data.keyIdeas.length > 0 && (
      <section class="container-prose section">
        <h2>Key ideas</h2>
        <ol class="ideas">
          {data.keyIdeas.map((idea) => <li>{idea}</li>)}
        </ol>
      </section>
    )}

    {data.whoShouldRead.length > 0 && (
      <section class="container-prose section grid-two">
        <div>
          <h3>Who should read this</h3>
          <ul>{data.whoShouldRead.map((line) => <li>{line}</li>)}</ul>
        </div>
        {data.whoShouldSkip.length > 0 && (
          <div>
            <h3>Who can skip it</h3>
            <ul>{data.whoShouldSkip.map((line) => <li>{line}</li>)}</ul>
          </div>
        )}
      </section>
    )}

    {Overview && (
      <section class="container-prose section prose">
        <h2>Overview</h2>
        <Overview />
      </section>
    )}
    {Content && (
      <section class="container-prose section prose">
        <h2>Content</h2>
        <Content />
      </section>
    )}
    {Analysis && (
      <section class="container-prose section prose">
        <h2>Analysis</h2>
        <Analysis />
      </section>
    )}
    {Narration && (
      <section class="container-prose section prose">
        <h2>Narration</h2>
        <Narration />
      </section>
    )}

    <footer class="container-prose section book-foot">
      <a href="/books/" class="back-link">← All books</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .book { padding-block: 3rem 4rem; }
  .book-head { margin-bottom: 3rem; max-width: 720px; }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.75rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  .eyebrow a:hover { color: var(--color-fg); }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 5vw, 3rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; line-height: 1.1; }
  .subtitle { font-family: var(--font-serif); color: var(--color-fg-muted); font-size: 1.25rem; font-style: italic; margin: 0.5rem 0 0; }
  .byline { color: var(--color-fg-muted); margin: 1rem 0 0; font-size: 0.9375rem; }
  .tag-row { list-style: none; padding: 0; margin: 1.25rem 0 0; display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.25rem 0.625rem;
  }

  .section { padding-block: 1.5rem; }
  .section h2 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 600; margin: 0 0 1rem; }
  .section h3 { font-family: var(--font-serif); font-size: 1.125rem; font-weight: 600; margin: 0 0 0.75rem; }
  .lede { font-size: 1.125rem; color: var(--color-fg); margin: 0; line-height: 1.6; }

  .ideas { padding-left: 1.5rem; margin: 0; color: var(--color-prose); }
  .ideas li { margin-bottom: 0.625rem; line-height: 1.6; }

  .grid-two { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .grid-two { grid-template-columns: 1fr 1fr; } }
  .grid-two ul { padding-left: 1.25rem; margin: 0; }
  .grid-two li { margin-bottom: 0.375rem; color: var(--color-prose); }

  .prose { color: var(--color-prose); line-height: 1.7; font-size: 1.0625rem; }
  .prose :global(p) { margin: 0 0 1rem; }
  .prose :global(h3) { margin: 1.5rem 0 0.75rem; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin: 0 0 1rem; }
  .prose :global(a) { color: var(--color-accent); }
  .prose :global(code) { background: var(--color-bg-muted); padding: 0.125em 0.375em; border-radius: 0.25rem; font-size: 0.875em; }

  .book-foot { padding-block: 2rem 0; }
  .back-link { color: var(--color-fg-muted); text-decoration: none; }
  .back-link:hover { color: var(--color-accent); }
</style>
