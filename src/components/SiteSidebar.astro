---
/**
 * Site sidebar — left-rail navigation specific to Book Lore. Wraps the
 * @chirag127/oriz-ui Sidebar React island and supplies link sections that make
 * sense for a structured book-summaries site, plus a Family quick-jump at the
 * bottom listing the other oriz sites.
 */
import { Sidebar, FAMILY_SITES } from '@chirag127/oriz-ui'

const sections = [
  {
    title: 'Browse',
    links: [
      { label: 'Latest', href: '/books/' },
      { label: 'Categories', href: '/categories/' },
      { label: 'Authors', href: '/books/?by=author' },
      { label: 'Themes', href: '/books/?by=tag' },
    ],
  },
  {
    title: 'Reading',
    links: [
      { label: 'Bookmarks', href: '/account/' },
      { label: 'Reading list', href: '/account/' },
      { label: 'Notes', href: '/account/' },
    ],
  },
  {
    title: 'Family',
    links: FAMILY_SITES.filter((s) => s.slug !== 'book-lore').map((s) => ({
      label: `${s.emoji}  ${s.name}`,
      href: s.url,
    })),
  },
]
---

<div class="sidebar-wrap">
  <Sidebar
    client:idle
    siteName="Book Lore"
    siteSlug="book-lore"
    sections={sections}
  />
</div>

<style>
  .sidebar-wrap { contain: layout; }
</style>
