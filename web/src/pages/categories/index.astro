---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');

interface LeafNode {
  name: string;
  slug: string;
  count: number;
}

interface SubNode {
  name: string;
  slug: string;
  count: number;
  leaves: Map<string, LeafNode>;
}

interface CatNode {
  name: string;
  slug: string;
  count: number;
  subcategories: Map<string, SubNode>;
}

function labelFromSlug(slug: string) {
  const cleaned = slug.replace(/^\d+-/, '');
  return cleaned
    .split('-')
    .map((word) => (['ai', 'eq', 'ui', 'ux', 'api', 'seo', 'devops'].includes(word) ? word.toUpperCase() : word.charAt(0).toUpperCase() + word.slice(1)))
    .join(' ');
}

const cats = new Map<string, CatNode>();

for (const b of books) {
  const cat = b.data.category ?? 'uncategorized';
  const sub = b.data.subcategory ?? 'general';
  const leaf = b.data.subtopic ?? 'general';

  if (!cats.has(cat)) {
    cats.set(cat, { name: labelFromSlug(cat), slug: cat, count: 0, subcategories: new Map() });
  }
  const c = cats.get(cat)!;
  c.count++;

  if (!c.subcategories.has(sub)) {
    c.subcategories.set(sub, { name: labelFromSlug(sub), slug: sub, count: 0, leaves: new Map() });
  }
  const s = c.subcategories.get(sub)!;
  s.count++;

  if (!s.leaves.has(leaf)) {
    s.leaves.set(leaf, { name: labelFromSlug(leaf), slug: leaf, count: 0 });
  }
  s.leaves.get(leaf)!.count++;
}

const sorted = Array.from(cats.values()).sort((a, b) => a.slug.localeCompare(b.slug));
const totalBooks = books.length;
const totalCategories = sorted.length;
const totalSubcategories = sorted.reduce((sum, cat) => sum + cat.subcategories.size, 0);
const totalLeaves = sorted.reduce(
  (sum, cat) => sum + Array.from(cat.subcategories.values()).reduce((leafSum, sub) => leafSum + sub.leaves.size, 0),
  0,
);
---

<BaseLayout
  title="Categories — KnowledgeAtlas"
  description={`Browse ${totalBooks} books across ${totalCategories} categories, ${totalSubcategories} subcategories, and ${totalLeaves} topic leaves.`}
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16 md:py-24">
    <p class="font-mono text-[0.6875rem] uppercase tracking-[0.22em] text-terracotta-500">
      The Atlas, organized
    </p>
    <h1 class="font-display text-display-lg font-light mt-4 mb-2 text-balance">
      Categories
    </h1>
    <p class="text-ink-soft text-pretty max-w-3xl">
      A three-level taxonomy for browsing, learning, and reference: top category, discipline subcategory, and focused topic leaf.
    </p>

    <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <div class="p-4 border border-rule grain-card">
        <div class="font-mono text-terracotta-500">{totalCategories}</div>
        <div class="text-ink-soft">Top categories</div>
      </div>
      <div class="p-4 border border-rule grain-card">
        <div class="font-mono text-terracotta-500">{totalSubcategories}</div>
        <div class="text-ink-soft">Subcategories</div>
      </div>
      <div class="p-4 border border-rule grain-card">
        <div class="font-mono text-terracotta-500">{totalLeaves}</div>
        <div class="text-ink-soft">Topic leaves</div>
      </div>
    </div>

    <div class="mt-12 sm:mt-16 space-y-8 sm:space-y-12">
      {sorted.map((cat) => (
        <section class="border-t border-rule pt-6 sm:pt-8">
          <div class="flex flex-wrap items-baseline gap-3 sm:gap-4 mb-4">
            <h2 class="font-display text-xl sm:text-2xl font-light">
              <a href={`/categories/${cat.slug}`} class="hover:text-terracotta-500 transition-colors">
                {cat.name}
              </a>
            </h2>
            <span class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">
              {cat.count} {cat.count === 1 ? 'book' : 'books'}
            </span>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
            {Array.from(cat.subcategories.values()).sort((a, b) => a.slug.localeCompare(b.slug)).map((sub) => (
              <a
                href={`/categories/${cat.slug}/${sub.slug}`}
                class="group p-4 border border-rule hover:border-terracotta-400 transition-colors"
              >
                <div class="flex items-start justify-between gap-3">
                  <span class="text-sm font-medium text-ink group-hover:text-terracotta-500 transition-colors">{sub.name}</span>
                  <span class="font-mono text-[0.625rem] uppercase tracking-[0.16em] text-ink-mute">{sub.count}</span>
                </div>
                <div class="mt-2 flex flex-wrap gap-2">
                  {Array.from(sub.leaves.values()).sort((a, b) => a.slug.localeCompare(b.slug)).slice(0, 5).map((leaf) => (
                    <span class="text-[0.6875rem] px-2 py-1 rounded-full bg-parchment-100 text-ink-soft">
                      {leaf.name} · {leaf.count}
                    </span>
                  ))}
                  {sub.leaves.size > 5 && (
                    <span class="text-[0.6875rem] px-2 py-1 rounded-full bg-parchment-100 text-ink-soft">
                      +{sub.leaves.size - 5}
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
