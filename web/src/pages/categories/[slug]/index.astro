---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const cats = new Set<string>();
  const books = await getCollection('books');
  for (const b of books) {
    if (b.data.category) cats.add(b.data.category);
  }
  return Array.from(cats).map(cat => ({ params: { slug: cat } }));
}

function labelFromSlug(slug: string) {
  const cleaned = slug.replace(/^\d+-/, '');
  return cleaned
    .split('-')
    .map((word) => (['ai', 'eq', 'ui', 'ux', 'api', 'seo', 'devops'].includes(word) ? word.toUpperCase() : word.charAt(0).toUpperCase() + word.slice(1)))
    .join(' ');
}

const { slug } = Astro.params;
const books = await getCollection('books');
const catBooks = books.filter(b => b.data.category === slug);

const overviewAll = await getCollection('overview');
const overviewEntry = overviewAll.find(e => e.id === `${slug}/00-index` || e.id.startsWith(`${slug}/`));
let Content = null;
if (overviewEntry) {
  const rendered = await render(overviewEntry);
  Content = rendered.Content;
}

interface LeafNode {
  name: string;
  slug: string;
  count: number;
}

interface SubInfo {
  name: string;
  slug: string;
  books: CollectionEntry<'books'>[];
  leaves: Map<string, LeafNode>;
}

const subMap = new Map<string, SubInfo>();
for (const b of catBooks) {
  const sub = b.data.subcategory ?? 'general';
  const leaf = b.data.subtopic ?? 'general';
  if (!subMap.has(sub)) {
    subMap.set(sub, { name: labelFromSlug(sub), slug: sub, books: [], leaves: new Map() });
  }
  const subInfo = subMap.get(sub)!;
  subInfo.books.push(b);
  if (!subInfo.leaves.has(leaf)) {
    subInfo.leaves.set(leaf, { name: labelFromSlug(leaf), slug: leaf, count: 0 });
  }
  subInfo.leaves.get(leaf)!.count++;
}
const subs = Array.from(subMap.values()).sort((a, b) => a.slug.localeCompare(b.slug));
const catName = labelFromSlug(slug ?? '');
const totalLeaves = subs.reduce((sum, sub) => sum + sub.leaves.size, 0);
---

<BaseLayout title={`${catName} — KnowledgeAtlas`} description={`Browse ${catBooks.length} books in ${catName}.`}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <p class="font-mono text-[0.6875rem] uppercase tracking-[0.22em] text-terracotta-500">
      <a href="/categories" class="hover:text-terracotta-600">Categories</a>
    </p>
    <h1 class="font-display text-display-lg font-light mt-4 mb-2 text-balance">
      {catName}
    </h1>
    <p class="text-ink-soft text-pretty max-w-2xl">
      {catBooks.length} {catBooks.length === 1 ? 'book' : 'books'} across {subs.length} subcategories and {totalLeaves} topic leaves.
    </p>

    {Content && (
      <div class="prose-bookatlas mt-8 p-5 sm:p-6 border border-rule grain-card grain-overlay">
        <Content />
      </div>
    )}

    <div class="mt-12 space-y-10">
      {subs.map((sub) => (
        <section class="border-t border-rule pt-6">
          <div class="flex flex-wrap items-baseline gap-3 mb-4">
            <h2 class="font-display text-xl font-light">
              <a href={`/categories/${slug}/${sub.slug}`} class="hover:text-terracotta-500 transition-colors">{sub.name}</a>
            </h2>
            <span class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">
              {sub.books.length} {sub.books.length === 1 ? 'book' : 'books'} · {sub.leaves.size} leaves
            </span>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-x-3 sm:gap-x-4 gap-y-3">
            {Array.from(sub.leaves.values()).sort((a, b) => a.slug.localeCompare(b.slug)).map((leaf) => (
              <a href={`/categories/${slug}/${sub.slug}/${leaf.slug}`} class="group p-3 border border-rule hover:border-terracotta-400 transition-colors">
                <div class="text-sm text-ink group-hover:text-terracotta-500 transition-colors">{leaf.name}</div>
                <div class="mt-1 font-mono text-[0.625rem] uppercase tracking-[0.16em] text-ink-mute">
                  {leaf.count} {leaf.count === 1 ? 'book' : 'books'}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
